{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Lucy Phase 1 Intent Classification",
  "type": "object",
  "required": [
    "intent_class",
    "confidence",
    "needs_current_info",
    "needs_personal_context",
    "style_mode",
    "mixed_intent",
    "candidate_routes",
    "needs_clarification",
    "clarification_question"
  ],
  "properties": {
    "intent_class": {
      "type": "string",
      "enum": [
        "local_knowledge",
        "current_fact",
        "evidence_check",
        "identity_personal",
        "command_control",
        "conversational",
        "technical_explanation",
        "mixed"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needs_current_info": {
      "type": "boolean"
    },
    "needs_personal_context": {
      "type": "boolean"
    },
    "style_mode": {
      "type": "string"
    },
    "mixed_intent": {
      "type": "boolean"
    },
    "candidate_routes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["LOCAL", "EVIDENCE", "NEWS", "CLARIFY"]
      },
      "minItems": 1
    },
    "needs_clarification": {
      "type": "boolean"
    },
    "clarification_question": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}

