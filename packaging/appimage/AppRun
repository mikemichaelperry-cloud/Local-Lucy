#!/bin/bash
# AppRun entry point for Local Lucy v10 AppImage.
# The AppImage mounts at $APPDIR; this script launches the bundled app.

set -e

# APPDIR is set by the AppImage runtime; fallback for local testing.
APPDIR="${APPDIR:-$(dirname "$(readlink -f "$0")")}"
export LUCY_ROOT="$APPDIR/opt/local-lucy"
export LUCY_UI_ROOT="$LUCY_ROOT/ui-v10"
export LUCY_RUNTIME_AUTHORITY_ROOT="$LUCY_ROOT"
export LUCY_RUNTIME_NAMESPACE_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/local-lucy"
export PATH="$LUCY_ROOT/ui-v10/.venv/bin:$PATH"

# Ensure the venv exists; if not, warn and fall back to system Python.
if [ ! -x "$LUCY_ROOT/ui-v10/.venv/bin/python" ]; then
    echo "Local Lucy venv not found at $LUCY_ROOT/ui-v10/.venv" >&2
    echo "Please run the installer or use the .deb package." >&2
    exit 1
fi

exec "$LUCY_ROOT/ui-v10/.venv/bin/python" -m tools.router_py.main "$@"
