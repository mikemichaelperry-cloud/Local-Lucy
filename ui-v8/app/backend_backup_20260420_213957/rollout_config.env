# Local Lucy Router - Python Rollout Configuration
# 
# This file controls the gradual rollout of the Python router.
# Copy to .env and adjust percentages as validation progresses.
#
# USAGE:
#   1. Source this file before running Local Lucy
#   2. Or set individual variables inline: LUCY_ROUTER_PY_PERCENTAGE=10 ./start.sh
#
# SAFETY: If anything goes wrong, set LUCY_ROUTER_PY=0 to force shell mode

# ============================================
# PHASE 5: GRADUAL ROLLOUT (Current Phase)
# ============================================

# Feature flag: Enable Python router
# 0 = Shell only (safe fallback)
# 1 = Python mode (use with LUCY_ROUTER_PY_PERCENTAGE)
# shadow = Compare both, log differences
LUCY_ROUTER_PY=1

# Rollout percentage: 0-100
# Only LUCY_ROUTER_PY_PERCENTAGE% of queries use Python
# Remaining use shell
LUCY_ROUTER_PY_PERCENTAGE=0

# Deterministic routing: Same query always uses same router
# true = Deterministic (easier debugging)
# false = Random (better statistical distribution)
LUCY_ROUTER_PY_DETERMINISTIC=true

# ============================================
# ROLLOUT PHASES (Adjust as validation proceeds)
# ============================================

# Phase 5.1: Initial Validation (Week 1-2)
# Target: 5% Python, 95% Shell
# LUCY_ROUTER_PY=1
# LUCY_ROUTER_PY_PERCENTAGE=5

# Phase 5.2: Early Adoption (Week 3-4)
# Target: 25% Python, 75% Shell
# LUCY_ROUTER_PY=1
# LUCY_ROUTER_PY_PERCENTAGE=25

# Phase 5.3: Majority Cutover (Week 5-6)
# Target: 50% Python, 50% Shell
# LUCY_ROUTER_PY=1
# LUCY_ROUTER_PY_PERCENTAGE=50

# Phase 5.4: Near Complete (Week 7-8)
# Target: 75% Python, 25% Shell
# LUCY_ROUTER_PY=1
# LUCY_ROUTER_PY_PERCENTAGE=75

# Phase 5.5: Full Cutover (Week 9+)
# Target: 95% Python, 5% Shell (emergency fallback)
# LUCY_ROUTER_PY=1
# LUCY_ROUTER_PY_PERCENTAGE=95

# ============================================
# MONITORING & SAFETY
# ============================================

# Emergency kill switch: Force shell mode regardless of other settings
# Set to 1 to immediately disable Python router
LUCY_ROUTER_PY_EMERGENCY_KILL=0

# Shadow mode logging: Log all comparisons even when using Python
# Useful for ongoing validation
LUCY_ROUTER_PY_SHADOW_LOG=0

# Performance threshold: Alert if Python is slower than shell
# Value is max acceptable slowdown factor (1.0 = same speed)
LUCY_ROUTER_PY_PERF_THRESHOLD=2.0

# ============================================
# DEBUGGING
# ============================================

# Verbose logging
LUCY_ROUTER_PY_DEBUG=0

# Trace execution (very verbose)
LUCY_ROUTER_PY_TRACE=0
