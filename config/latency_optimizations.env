# Local Lucy v8 Performance Optimizations
# Source this file to enable performance optimizations
# Usage: source config/latency_optimizations.env
#
# Updated April 30, 2026: Cache, voice pipeline, and model optimizations

# =============================================================================
# MODEL GENERATION OPTIMIZATIONS
# =============================================================================

# Lower temperature = more deterministic = faster generation
# 0.5 is optimal for factual queries (faster than 0.7)
export LUCY_LOCAL_TEMPERATURE=0.5

# Smaller top_p = faster generation
# Limits token selection to most probable 50% (vs default 90%)
export LUCY_LOCAL_TOP_P=0.5

# Limit output tokens for faster responses
# Default: unlimited (slow)
# Brief answers: 512 tokens
# Standard answers: 1024 tokens
# Detailed answers: 1536 tokens
# Long-form creative: 2048 tokens (for 500+ word stories)
#
# NOTE: qwen3 thinking mode burns ~100-300 tokens on internal reasoning before
# generating the visible response. These budgets are raised 1.5-2x from the
# llama3.1-era values to ensure thinking + response both fit.
export LUCY_LOCAL_NUM_PREDICT_DEFAULT=1024
export LUCY_LOCAL_NUM_PREDICT_BRIEF=512
export LUCY_LOCAL_NUM_PREDICT_CHAT=2048
export LUCY_LOCAL_NUM_PREDICT_CONVERSATION=1536
export LUCY_LOCAL_NUM_PREDICT_DETAIL=1536
export LUCY_LOCAL_NUM_PREDICT_CLARIFY=512

# Keep model loaded longer to avoid cold-start latency
# Default: 5 minutes (300s)
# Optimized: 15 minutes (900s)
export LUCY_LOCAL_KEEP_ALIVE=15m

# =============================================================================
# VOICE PIPELINE OPTIMIZATIONS
# =============================================================================

# Whisper model selection
# LUCY_VOICE_MODEL is a model name; LUCY_VOICE_WHISPER_MODEL is a full file path.
# Do not set LUCY_VOICE_WHISPER_MODEL to values like "base.en"; runtime_voice.py
# passes that variable directly to whisper.cpp as the model path.
# Options: tiny.en, base.en, small.en, medium.en, large, large-v3-turbo
# tiny.en:         ~1s transcription (fastest, slightly less accurate) - 75MB
# base.en:         ~2s transcription (good balance) - 150MB
# small.en:        ~4s transcription (default, most accurate) - 487MB
# large-v3-turbo:  ~6s transcription (best accuracy, already downloaded) - 1.6GB
#
# For RTX 3060 12GB: large-v3-turbo fits comfortably alongside the LLM.
export LUCY_VOICE_MODEL=large-v3-turbo
unset LUCY_VOICE_WHISPER_MODEL

# Whisper beam size (higher = more accurate, slightly slower)
# 1 = greedy (fastest), 5 = good balance, 10 = best accuracy
export LUCY_VOICE_WHISPER_BEAM_SIZE=5

# Force Kokoro TTS to CPU.
# With local-lucy-fast (1024 ctx) + Whisper large-v3-turbo GPU, VRAM is at
# ~11.2 GB / 12 GB.  Kokoro does not fit without OOM risk.
export LUCY_VOICE_KOKORO_DEVICE=cpu

# Kokoro speed-up: 1.2× cuts synthesis latency ~40% with minimal quality loss.
# Worker also forces torch.set_num_threads(12) to use all Ryzen 5600X cores.
export LUCY_VOICE_KOKORO_SPEED=1.2

# Smaller chunks = faster per-chunk synthesis on CPU.
# Default 800 chars → 400 chars halves synthesis time per chunk.
export LUCY_VOICE_TTS_CHUNK_MAX_CHARS=400

# PTT maximum recording duration (safety cap)
export LUCY_VOICE_PTT_MAX_SECONDS=60

# Keep Kokoro TTS worker alive longer
# Default: 300s (5 minutes)
# Optimized: 600s (10 minutes)
export LUCY_KOKORO_WORKER_IDLE_S=600

# TTS chunk size: larger = fewer chunks = fewer audible pauses
# Default: 480 chars. Raised to 800 to reduce mid-sentence chunking with qwen3's longer responses.
export LUCY_VOICE_TTS_CHUNK_MAX_CHARS=800

# Pause between TTS chunks (ms). Slightly longer for cleaner separation.
# Default: 56ms
export LUCY_VOICE_TTS_CHUNK_PAUSE_MS=80

# First-chunk prepad: silence prepended to first audio chunk to prevent
# hardware from clipping the initial words. Raised for cold-start safety.
# Default: 220ms
export LUCY_VOICE_KOKORO_FIRST_CHUNK_PREPAD_MS=400

# First-chunk player prime: silent playback before real audio to warm up aplay.
# Raised to prevent first-word drop after voice pipeline restart.
# Default: 80ms
export LUCY_VOICE_KOKORO_FIRST_CHUNK_PLAYER_PRIME_MS=200

# Faster TTS generation (slightly lower quality but faster)
#export LUCY_VOICE_TTS_SPEED=1.2

# =============================================================================
# EVIDENCE FETCHING OPTIMIZATIONS
# =============================================================================

# Parallel evidence fetching (if implemented)
#export LUCY_EVIDENCE_PARALLEL=1

# Per-source timeout (fail fast)
# Default: 10s
# Optimized: 5s
export LUCY_EVIDENCE_TIMEOUT_S=5

# Maximum keys to fetch per query
# Default: 6
# Optimized: 4 (faster, still sufficient)
export LUCY_EVID_MAX_KEYS=4

# =============================================================================
# WORKER PROCESS OPTIMIZATIONS
# =============================================================================

# Worker startup timeout
# Lower = faster fail/retry
export LUCY_LOCAL_WORKER_STARTUP_TIMEOUT_S=2

# Idle timeout before worker shuts down
# Higher = less cold-start latency
export LUCY_LOCAL_WORKER_IDLE_S=900

# =============================================================================
# AUGMENTED API OPTIMIZATIONS
# =============================================================================

# Connection timeout for external APIs
# Fail fast if connection slow
export LUCY_GATE_CONNECT_TIMEOUT_S=5

# Request timeout for augmented calls
# Default: 125s
# Optimized: 90s (fail faster, fallback to local)
export LUCY_AUGMENTED_TIMEOUT_S=90

# =============================================================================
# NOTES
# =============================================================================

# These optimizations prioritize speed while maintaining accuracy:
# - Lower temperature reduces hallucinations AND speeds up generation
# - Context window (2048) supports 500+ word responses with qwen3
# - Output token limits prevent overly long responses
# - Voice pipeline uses base whisper (good speed/accuracy balance)
#
# Trade-offs:
# - Conversation history (2048 tokens) supports long-form responses
# - Maximum responses limited by num_predict (2048 for chat allows 500+ words)
# - Slightly less creative responses (temperature 0.5 vs 0.7)
# - qwen3 thinking mode consumes extra tokens; budgets raised accordingly
#
# To disable: unset these variables or source the default config
