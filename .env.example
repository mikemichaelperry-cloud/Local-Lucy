# Local Lucy V8 — Environment Configuration
# Copy this file to .env and fill in your API keys.
# Only required if you want cloud-augmented modes or news.

# =============================================================================
# LOCAL LLM (Required — Ollama)
# =============================================================================
# The Ollama model name. Default is created from config/Modelfile.local-lucy
# LUCY_LOCAL_MODEL=local-lucy

# =============================================================================
# CLOUD PROVIDERS (Optional — for augmented / evidence modes)
# =============================================================================
# At least one provider key is recommended for complex factual queries.

# OpenAI / ChatGPT
# OPENAI_API_KEY=sk-...

# Kimi (Moonshot AI)
# KIMI_API_KEY=...
# MOONSHOT_API_KEY=...

# Grok (xAI)
# GROK_API_KEY=...

# =============================================================================
# NEWS (Optional — for NEWS route)
# =============================================================================
# Get a free key at https://newsapi.org
# NEWSAPI_API_KEY=...

# =============================================================================
# LEARNING (Optional — defaults are sensible)
# =============================================================================
# Enable auto-learning from feedback
# LUCY_AUTO_LEARN=1

# Thresholds for triggering background learner rebuild
# LUCY_AUTO_LEARN_THRESHOLD=3
# LUCY_AUTO_FEEDBACK_THRESHOLD=5

# Cap auto-feedback confidence to prevent low-trust corrections from dominating
# LUCY_AUTO_FEEDBACK_MAX_CONFIDENCE=0.5

# =============================================================================
# PERFORMANCE (Optional)
# =============================================================================
# Enable latency optimizations (token limits, caching)
# source config/latency_optimizations.env
